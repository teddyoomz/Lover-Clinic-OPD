{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/admin/branch-backup-export.js": {
      "maxDuration": 60
    },
    "api/admin/branch-restore.js": {
      "maxDuration": 60
    },
    "api/admin/branch-make-fresh.js": {
      "maxDuration": 60
    },
    "api/admin/branch-backups.js": {
      "maxDuration": 30
    },
    "api/admin/whole-fleet-customer-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/whole-fleet-customer-restore.js": {
      "maxDuration": 300
    },
    "api/cron/line-reminder-fire.js": {
      "maxDuration": 300
    },
    "api/cron/line-reminder-retry.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/line-reminder-fire",  "schedule": "0 * * * *" },
    { "path": "/api/cron/line-reminder-retry", "schedule": "*/5 * * * *" }
  ]
}
