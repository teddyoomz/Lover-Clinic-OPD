{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/admin/branch-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/branch-restore.js": {
      "maxDuration": 300
    },
    "api/admin/branch-make-fresh.js": {
      "maxDuration": 300
    },
    "api/admin/branch-backups.js": {
      "maxDuration": 30
    },
    "api/admin/whole-fleet-customer-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/whole-fleet-customer-restore.js": {
      "maxDuration": 300
    },
    "api/admin/run-scheduled-task.js": {
      "maxDuration": 300
    },
    "api/cron/line-reminder-fire.js": {
      "maxDuration": 300
    },
    "api/cron/line-reminder-retry.js": {
      "maxDuration": 300
    },
    "api/admin/whole-system-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/whole-system-restore.js": {
      "maxDuration": 300
    },
    "api/admin/whole-system-backup-download.js": {
      "maxDuration": 300
    },
    "api/cron/whole-system-backup-daily.js": {
      "maxDuration": 300
    },
    "api/cron/stock-movement-retention.js": {
      "maxDuration": 300
    },
    "api/cron/stock-lot-cleanup.js": {
      "maxDuration": 300
    },
    "api/cron/chart-edit-session-sweep.js": {
      "maxDuration": 60
    },
    "api/cron/staff-chat-retention-sweep.js": {
      "maxDuration": 300
    },
    "api/cron/chat-history-retention-sweep.js": {
      "maxDuration": 300
    },
    "api/cron/opd-session-cleanup-sweep.js": {
      "maxDuration": 300
    },
    "api/admin/customer-only-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/customer-only-restore.js": {
      "maxDuration": 300
    },
    "api/admin/customer-only-backup-download.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/line-reminder-fire",  "schedule": "0 * * * *" },
    { "path": "/api/cron/line-reminder-retry", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/whole-system-backup-daily", "schedule": "0 20 * * *" },
    { "path": "/api/cron/stock-movement-retention", "schedule": "30 20 * * *" },
    { "path": "/api/cron/stock-lot-cleanup", "schedule": "45 20 * * *" },
    { "path": "/api/cron/chart-edit-session-sweep", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/staff-chat-retention-sweep", "schedule": "45 19 * * *" },
    { "path": "/api/cron/chat-history-retention-sweep", "schedule": "0 21 * * *" },
    { "path": "/api/cron/opd-session-cleanup-sweep", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/patient-link-cleanup-sweep", "schedule": "30 21 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'sha256-jhKhyPvr0JOQoE9IF68QXUG8JTbLtGj3uqD2F6mECq0=' 'sha256-T+bx+QVVwvjDDdzlgJkDATGtn1kUUXXH67ga61CdNlw='; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; media-src 'self' https: data: blob:; connect-src 'self' https://*.googleapis.com wss://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.firebasestorage.app https://*.cloudfunctions.net https://www.gstatic.com; worker-src 'self' blob:; manifest-src 'self'; frame-src 'self'; frame-ancestors 'self'; form-action 'self'; upgrade-insecure-requests" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "off" }
      ]
    }
  ]
}
