{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/admin/branch-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/branch-restore.js": {
      "maxDuration": 300
    },
    "api/admin/branch-make-fresh.js": {
      "maxDuration": 300
    },
    "api/admin/branch-backups.js": {
      "maxDuration": 30
    },
    "api/admin/whole-fleet-customer-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/whole-fleet-customer-restore.js": {
      "maxDuration": 300
    },
    "api/admin/run-scheduled-task.js": {
      "maxDuration": 300
    },
    "api/cron/line-reminder-fire.js": {
      "maxDuration": 300
    },
    "api/cron/line-reminder-retry.js": {
      "maxDuration": 300
    },
    "api/admin/whole-system-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/whole-system-restore.js": {
      "maxDuration": 300
    },
    "api/admin/whole-system-backup-download.js": {
      "maxDuration": 300
    },
    "api/cron/whole-system-backup-daily.js": {
      "maxDuration": 300
    },
    "api/cron/stock-movement-retention.js": {
      "maxDuration": 300
    },
    "api/cron/stock-lot-cleanup.js": {
      "maxDuration": 300
    },
    "api/cron/chart-edit-session-sweep.js": {
      "maxDuration": 60
    },
    "api/cron/staff-chat-retention-sweep.js": {
      "maxDuration": 300
    },
    "api/cron/chat-history-retention-sweep.js": {
      "maxDuration": 300
    },
    "api/cron/opd-session-cleanup-sweep.js": {
      "maxDuration": 300
    },
    "api/admin/customer-only-backup-export.js": {
      "maxDuration": 300
    },
    "api/admin/customer-only-restore.js": {
      "maxDuration": 300
    },
    "api/admin/customer-only-backup-download.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/line-reminder-fire",  "schedule": "0 * * * *" },
    { "path": "/api/cron/line-reminder-retry", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/whole-system-backup-daily", "schedule": "0 20 * * *" },
    { "path": "/api/cron/stock-movement-retention", "schedule": "30 20 * * *" },
    { "path": "/api/cron/stock-lot-cleanup", "schedule": "45 20 * * *" },
    { "path": "/api/cron/chart-edit-session-sweep", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/staff-chat-retention-sweep", "schedule": "45 19 * * *" },
    { "path": "/api/cron/chat-history-retention-sweep", "schedule": "0 21 * * *" },
    { "path": "/api/cron/opd-session-cleanup-sweep", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/patient-link-cleanup-sweep", "schedule": "30 21 * * *" }
  ]
}
