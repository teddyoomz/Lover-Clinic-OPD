rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // V33-customer-create (2026-04-27) — V26 catch-up: migrated from email
    // regex (`request.auth.token.email.matches('.*@loverclinic[.]com$')`)
    // to claim-based gating, mirroring firestore.rules `isClinicStaff()`.
    // This closes the same security-theater gap V26 closed in firestore.rules:
    // any Firebase user with @loverclinic.com email could write here even
    // without staff-grant claims. Now requires `isClinicStaff:true` OR
    // `admin:true` custom claim set via /api/admin/users.
    function isClinicStaff() {
      return request.auth != null && (
        request.auth.token.isClinicStaff == true ||
        request.auth.token.admin == true
      );
    }

    // ─── V40 + V74 — backup storage (admin-only) ──────────────────────────
    // Patterns covered by this rule (single-segment prefix + file path):
    //   - V40: backups/{branchId}/*.json — branch backup files
    //   - V40: backups/{branchId}/storage/... — branch backup Storage tree (post-2026-05-14)
    //   - V40: backups/central-stock/.../* — central stock backup files (V15)
    //   - V74: backups/customers/{customerId}/{ts-rand}/backup.json — per-customer backup
    //   - V74: backups/customers/{customerId}/{ts-rand}/storage/... — Storage tree
    // Admin SDK bypasses these rules (server endpoints write here directly);
    // rule gates client-side anonymous reads via signed URLs (server mints
    // 24h signed URLs for admin to download/share). Variable name
    // {prefix} captures any of: branches / central-stock / customers.
    // Probe-Deploy-Probe #7 (V40 branch) + #11 (V74 customer) verify
    // anon write returns 401/403.
    match /backups/{prefix}/{file=**} {
      allow read, write, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ─── V106 (2026-05-20) — stock-movement retention archive (admin-only) ──
    // Pattern: stock-movements-archive/{branchId}/{YYYY-MM}.json
    // Permanent audit archive written by the daily retention cron
    // (api/cron/stock-movement-retention.js) via admin SDK, which bypasses
    // these rules. Client read/write blocked (medical audit data). The
    // default-deny catch-all already blocks unmatched paths; this explicit
    // match documents intent + mirrors the backups/ admin-only contract.
    // Probe-Deploy-Probe: anon write to stock-movements-archive/ → 403.
    match /stock-movements-archive/{branchId}/{file=**} {
      allow read, write, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ─── Chart templates (2026-05-22 EOD+1) ───────────────────────────────
    // Pattern: chart-templates/{templateId}.{ext}
    // ChartTemplateSelector uploads user-added chart background images here
    // (universal — same image visible across all branches per user requirement
    // "ไม่ต้องเก็บแยกสาขา"). The Firestore doc be_chart_templates/{templateId}
    // holds the download URL. READ is permissive (isSignedIn) because patients
    // hit TFP via anon-auth and need to load chart images. WRITE/DELETE staff
    // only. Image-only MIME gate + 10MB cap (charts are typically 200KB-2MB
    // JPG/PNG/SVG — pen+anatomy diagrams, not high-res photos).
    // Probe-Deploy-Probe #14: anon write here → 403; staff write → 200.
    match /chart-templates/{file=**} {
      allow read: if request.auth != null;  // signed-in (staff OR patient anon)
      allow create, update: if isClinicStaff()
                            && request.resource.size < 10 * 1024 * 1024
                            && request.resource.contentType.matches('image/.*');
      allow delete: if isClinicStaff();
    }

    // ─── V73 Feature F (2026-05-16) — Staff chat attachments ──────────────
    // (2026-05-22) Multi-image: staff-chat-attachments/{branchId}/{messageId}/{id}-{t|o}.{ext}
    //   — thumbnail (~512px jpeg, tiny) + original. {file=**} matches the nested
    //   {messageId}/ folder. (2026-05-22 any-file) Split cap (Q4): image/* < 50MB;
    //   every other file type < 1GB. Render kind is derived client-side from mime.
    // Clinic-staff-only WRITE + READ. UPDATE + DELETE blocked (append-only by
    // design; the retention cron deletes via admin SDK which bypasses these rules
    // — keeps client-delete locked for defense-in-depth).
    match /staff-chat-attachments/{branchId}/{file=**} {
      allow read: if request.auth != null && (request.auth.token.isClinicStaff == true || request.auth.token.admin == true);
      allow create: if request.auth != null
                    && (request.auth.token.isClinicStaff == true || request.auth.token.admin == true)
                    && (
                         (request.resource.contentType.matches('image/.*')  && request.resource.size < 50 * 1024 * 1024)
                      || (!request.resource.contentType.matches('image/.*') && request.resource.size < 1024 * 1024 * 1024)
                    );
      allow update: if false;
      // (2026-05-26) Feature 3 Unsend — clinic-staff may delete (the unsend
      // handler sweeps this message's folder; retention cron uses admin SDK).
      allow delete: if request.auth != null
                    && (request.auth.token.isClinicStaff == true || request.auth.token.admin == true);
    }

    // Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // V33-customer-create — explicit be_customers path (profile + gallery uploads).
    // Stricter MIME gating: image/* OR pdf only; max 10MB.
    match /uploads/be_customers/{customerId}/{file=**} {
      allow read: if isClinicStaff();
      allow create: if isClinicStaff()
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf');
      allow delete: if isClinicStaff();
    }

    // ─── Tablet chart-editor relay transport (2026-05-21) ────────────────
    // Pattern: uploads/chart-edit-sessions/{sessionId}/{template.png|result.png|result.json}
    // The relay transports the template + flattened result as image/* AND the
    // editor's object model as result.json (application/json — the lossless,
    // re-editable fabricJson). The generic uploads rule below allows ONLY
    // image/* + pdf, so the client-SDK result.json upload (application/json)
    // was DENIED → uploadTransportJson threw → the whole onSave rejected → save
    // failed silently (the admin-SDK L2 e2e missed it — admin bypasses rules).
    // This match allows image/* + application/json, staff-only, 10MB cap.
    // Probe-Deploy-Probe #13: anon write here → 403; staff json write → 200.
    match /uploads/chart-edit-sessions/{sessionId}/{file=**} {
      allow read: if isClinicStaff();
      allow create: if isClinicStaff()
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/json');
      allow delete: if isClinicStaff();
    }

    // Generic uploads — clinic staff only (other be_* collections like
    // be_treatments, be_documents, etc. land here). Same MIME + size gate.
    match /uploads/{collection}/{docId}/{fileName} {
      allow read: if isClinicStaff();
      allow create: if isClinicStaff()
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf');
      allow delete: if isClinicStaff();
    }
  }
}
