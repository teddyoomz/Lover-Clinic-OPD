rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // V33-customer-create (2026-04-27) — V26 catch-up: migrated from email
    // regex (`request.auth.token.email.matches('.*@loverclinic[.]com$')`)
    // to claim-based gating, mirroring firestore.rules `isClinicStaff()`.
    // This closes the same security-theater gap V26 closed in firestore.rules:
    // any Firebase user with @loverclinic.com email could write here even
    // without staff-grant claims. Now requires `isClinicStaff:true` OR
    // `admin:true` custom claim set via /api/admin/users.
    function isClinicStaff() {
      return request.auth != null && (
        request.auth.token.isClinicStaff == true ||
        request.auth.token.admin == true
      );
    }

    // ─── V40 + V74 — backup storage (admin-only) ──────────────────────────
    // Patterns covered by this rule (single-segment prefix + file path):
    //   - V40: backups/{branchId}/*.json — branch backup files
    //   - V40: backups/{branchId}/storage/... — branch backup Storage tree (post-2026-05-14)
    //   - V40: backups/central-stock/.../* — central stock backup files (V15)
    //   - V74: backups/customers/{customerId}/{ts-rand}/backup.json — per-customer backup
    //   - V74: backups/customers/{customerId}/{ts-rand}/storage/... — Storage tree
    // Admin SDK bypasses these rules (server endpoints write here directly);
    // rule gates client-side anonymous reads via signed URLs (server mints
    // 24h signed URLs for admin to download/share). Variable name
    // {prefix} captures any of: branches / central-stock / customers.
    // Probe-Deploy-Probe #7 (V40 branch) + #11 (V74 customer) verify
    // anon write returns 401/403.
    match /backups/{prefix}/{file=**} {
      allow read, write, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ─── V73 Feature F (2026-05-16) — Staff chat image attachments ────────
    // Pattern: staff-chat-attachments/{branchId}/{timestamp}-{hex}.jpg
    // Clinic-staff-only WRITE (client-side resize → JPEG → upload), and
    // clinic-staff-only READ. 1 MB cap (resized images at maxDim=1024 +
    // quality 0.85 land well under this — caps abuse paths). UPDATE +
    // DELETE blocked (append-only by design; admin SDK can sweep via
    // future cleanup endpoint if needed).
    match /staff-chat-attachments/{branchId}/{file=**} {
      allow read: if request.auth != null && (request.auth.token.isClinicStaff == true || request.auth.token.admin == true);
      allow create: if request.auth != null
                    && (request.auth.token.isClinicStaff == true || request.auth.token.admin == true)
                    && request.resource.size < 1 * 1024 * 1024;
      allow update, delete: if false;
    }

    // Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // V33-customer-create — explicit be_customers path (profile + gallery uploads).
    // Stricter MIME gating: image/* OR pdf only; max 10MB.
    match /uploads/be_customers/{customerId}/{file=**} {
      allow read: if isClinicStaff();
      allow create: if isClinicStaff()
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf');
      allow delete: if isClinicStaff();
    }

    // Generic uploads — clinic staff only (other be_* collections like
    // be_treatments, be_documents, etc. land here). Same MIME + size gate.
    match /uploads/{collection}/{docId}/{fileName} {
      allow read: if isClinicStaff();
      allow create: if isClinicStaff()
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType == 'application/pdf');
      allow delete: if isClinicStaff();
    }
  }
}
