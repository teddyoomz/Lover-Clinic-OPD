{
  "manifest_version": 3,
  "name": "Lover Clinic → ProClinic Broker",
  "version": "1.0.0",
  "description": "ส่งข้อมูลคนไข้จาก Lover Clinic ไปกรอกใน ProClinic อัตโนมัติ",
  "permissions": ["tabs", "scripting", "storage", "activeTab", "alarms", "cookies"],
  "host_permissions": [
    "https://lover-clinic-app.vercel.app/*",
    "https://trial.proclinicth.com/*",
    "https://*.proclinicth.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://lover-clinic-app.vercel.app/*"],
      "js": ["content-loverclinic.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lover Clinic Broker",
    "default_badge_text": ""
  }
}
