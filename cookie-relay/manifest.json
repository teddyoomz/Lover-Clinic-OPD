{
  "manifest_version": 3,
  "name": "LoverClinic Cookie Relay",
  "version": "1.1",
  "description": "Auto-sync ProClinic session cookies + auto-login for LoverClinic webapp",
  "permissions": ["cookies", "scripting", "tabs", "storage"],
  "host_permissions": ["https://*.proclinicth.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LoverClinic Cookie Relay"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lover-clinic-app.vercel.app/*",
        "http://localhost:*/*"
      ],
      "js": ["content-loverclinic.js"],
      "run_at": "document_start"
    }
  ]
}
