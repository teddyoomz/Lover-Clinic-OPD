rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isClinicStaff() {
      // Phase 13.5.4 Deploy 2 (V26, 2026-04-26) — narrowed from email-only
      // check to Firebase Auth custom claims. Closes security gap where any
      // user with @loverclinic.com email could read/write be_* via SDK.
      // Prerequisites (all done in Deploy 1):
      //   - /api/admin/users setPermission action sets isClinicStaff:true
      //   - StaffFormModal auto-syncs claims after staff save
      //   - PermissionGroupsTab "Sync ทุก staff → Claims" button backfills
      //   - /api/admin/bootstrap-self grants genesis admin (admin + isClinicStaff)
      // Either claim suffices: `admin:true` (bootstrap/grantAdmin path) OR
      // `isClinicStaff:true` (per-staff via setPermission). Defense-in-depth.
      return isSignedIn() && (
        request.auth.token.isClinicStaff == true ||
        request.auth.token.admin == true
      );
    }

    // ── Default deny all ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ════════════════════════════════════════════════════════════════
    // ARTIFACTS — Main data path: artifacts/{appId}/public/data/...
    // ════════════════════════════════════════════════════════════════
    match /artifacts/{appId}/public/data/{document=**} {

      // ── Clinic Settings (read: anyone for public settings, write: staff only) ──
      match /clinic_settings/{settingId} {
        // WS1 C2-bis (2026-06-10) — chat_config holds LINE/FB channel SECRETS and
        // MUST NOT be public. Firestore unions (OR) ALL matching rules, so a more-
        // specific `clinic_settings/chat_config` match CANNOT restrict what this
        // wildcard grants — the exclusion has to live HERE. (Confirmed live: a
        // specific staff-only chat_config match left it readable at HTTP 200 because
        // `true OR isClinicStaff == true`.) Other docs (main/theme/logo, system_config
        // read by App.jsx v86Glow on anon patient loads, schedule_prefs, counters)
        // stay public. chat_config falls through to its staff-only specific match.
        allow read: if settingId != 'chat_config';
        allow write: if isClinicStaff();
      }

      // ── Phase 16.3 (2026-04-29) — System Settings ──
      // Single doc storing tab-visibility overrides + defaults + feature
      // flags. Q2-C: write gated by NEW permission key
      // `system_config_management` OR admin claim. Read: any clinic-staff
      // (UI consumers + backendClient._deductOneItem stock-deduct gate).
      // More specific match takes precedence over the wildcard above.
      match /clinic_settings/system_config {
        allow read: if isClinicStaff();
        allow write: if isSignedIn() && (
          request.auth.token.admin == true ||
          request.auth.token['perm_system_config_management'] == true
        );
      }

      // ── WS1 C2-bis (2026-06-10) — CRITICAL secret lockdown ──
      // clinic_settings/chat_config holds LINE + FB channel SECRETS
      // (line.channelSecret/channelAccessToken, facebook.appSecret/
      // pageAccessToken/verifyToken). C2 (2bcba3e9) migrated the only unauth-REST
      // reader (webhook getChatConfig) to the admin SDK but NEVER closed the rule.
      // IMPORTANT — Firestore UNIONS (OR) all matching rules: this specific match
      // canNOT restrict; the actual lockdown is the `settingId != 'chat_config'`
      // EXCLUSION in the wildcard above (a prior staff-only specific match alone
      // left it readable at HTTP 200 because `true OR isClinicStaff == true`).
      // This match's job is to GRANT staff read/write to chat_config (the wildcard
      // now denies it). Readers: webhook getChatConfig = admin SDK (bypasses rules);
      // ChatPanel + Line/FbSettingsTab = staff client (isClinicStaff claim).
      // Rule B probe: unauth GET clinic_settings/chat_config → must be 403.
      // ⚠ The secrets were publicly exposed for an unknown window — the LINE
      // channelSecret/accessToken + FB appSecret/pageAccessToken MUST be
      // ROTATED (this rule stops future reads; rotation handles scraped values).
      match /clinic_settings/chat_config {
        allow read, write: if isClinicStaff();
      }

      // ── Form Templates (custom intake/follow-up forms — staff-authored) ──
      // Read: any signed-in user (admin + kiosk) needs to render forms.
      // Write: clinic staff only.
      match /form_templates/{templateId} {
        // WS1 M2 (2026-06-10) — split read. PatientForm does not read this
        // collection; the only readers are the staff form-builder. GET-by-id stays
        // open to any signed-in (defensive — in case a patient renders a custom
        // form by id); LIST is staff-only to kill anon enumeration of form structures.
        allow get:  if isSignedIn();
        allow list: if isClinicStaff();
        allow write: if isClinicStaff();
      }

      // ── OPD Sessions (patient form submissions) ──
      // V23 (2026-04-26) — narrowed `update: if isClinicStaff()` after bug
      // "ตอนนี้กดส่งข้อมูลคนไข้ผ่านลิ้งหรือ QR code แล้วขึ้นผิดพลาดตลอด
      // ส่งไม่ได้". Patients reach the form via signInAnonymously
      // (App.jsx:89) — anon users have no @loverclinic.com email → the
      // staff check fails → PERMISSION_DENIED on PatientForm submit
      // + PatientDashboard course-refresh.
      // Fix: whitelist the exact 11 fields anon clients legitimately
      // write (PatientForm.jsx:372 + PatientDashboard.jsx:403,410).
      // Staff can still write any field. Mirrors V19 hasOnly() pattern.
      // Anon attacker who guesses a sessionId can only modify those 11
      // fields — cannot flip isArchived, sessionName, formType,
      // customTemplate, createdAt, brokerProClinicId, patientLinkToken.
      //
      // V27-tris (2026-04-26) — allow anon DELETE only on doc IDs that
      // start with `test-probe-anon-` (Rule B probe artifacts).
      // Without this, every deploy left visible queue clutter that only
      // staff (with claims) could remove. Self-cleanup pattern keeps
      // production queue tidy automatically. Real session IDs are
      // DEP-XXXXXX / QR-XXXXXX / IMP-XXXXXX — never start with
      // `test-probe-anon-`, so legit data is unreachable by this branch.
      match /opd_sessions/{sessionId} {
        // WS1 C1 (2026-06-10) — split read into get/list. Anon may GET a session
        // by its crypto-random doc-id (the patient-link secret, now 128-bit) but
        // may NOT LIST/enumerate the collection. Kills the mass-PII dump (national
        // ID + medical) via an anon getDocs(opd_sessions). Patient submit + the
        // dashboard only ever get-by-id; staff (claim) keep full list.
        // Rule B probe: anon list → DENIED; anon get-by-id → 200.
        allow get:  if isSignedIn();
        allow list: if isClinicStaff();
        allow create: if true;  // Patients (anon) can create new sessions
        allow update: if isClinicStaff() ||
          (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'patientData', 'submittedAt', 'updatedAt', 'isUnread',
                     'lastCoursesAutoFetch', 'coursesRefreshRequest',
                     'brokerStatus', 'brokerError', 'brokerJob', 'latestCourses']));
        allow delete: if isClinicStaff() ||
          (isSignedIn() && sessionId.matches('^test-probe-anon-.*$'));
      }

      // ── Backend: Customers (cloned from ProClinic OR manually created via CustomerFormModal) ──
      match /be_customers/{customerId} {
        allow read, write: if isClinicStaff();
      }
      // V33-customer-create — HN counter (atomic via runTransaction).
      match /be_customer_counter/{docId} {
        allow read, write: if isClinicStaff();
      }
      // 2026-06-16 Part A — identity-claim (Rule T bulletproof dup-prevention).
      // doc-id = type-prefixed key (CITIZEN:{13d} | PASSPORT:{UPPER}).
      //
      // 🚨 CRITICAL PII INVARIANT — `allow list: if false` MUST NEVER be relaxed.
      // The doc-id embeds the national id; `list:false` makes the collection
      // non-enumerable (read by exact id ONLY). A future "admin audit list" must
      // NOT add `allow list` here — it would expose the entire clinic's national-id
      // set in one scan. (Marginal exposure today is ~nil — the same ids already
      // live staff-readable on be_customers.citizen_id — but list:false keeps this
      // collection from WIDENING that surface; the audit grep + probe #17 lock it.)
      //
      // create/update/delete are required: the claim is set at create, appended on
      // override, re-pointed on edit, and freed on customer delete — so create-only
      // immutable was REJECTED (it would orphan claims). Probe-Deploy-Probe: anon
      // write → 403.
      match /be_customer_identity/{claimKey} {
        allow get: if isClinicStaff();
        allow list: if false;
        allow create, update, delete: if isClinicStaff();
      }

      // ── Backend: Treatments ──
      match /be_treatments/{treatmentId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Appointments ──
      match /be_appointments/{appointmentId} {
        allow read, write: if isClinicStaff();
      }

      // ── V73 Staff Chat ──
      match /be_staff_chat_messages/{msgId} {
        allow read: if isClinicStaff();
        allow create: if isClinicStaff()
                      && request.resource.data.branchId is string
                      && request.resource.data.branchId.size() > 0
                      && request.resource.data.displayName is string
                      && request.resource.data.displayName.size() >= 2
                      && request.resource.data.displayName.size() <= 50
                      && request.resource.data.deviceId is string
                      && request.resource.data.deviceId.size() > 0
                      && request.resource.data.get('text', '') is string
                      && request.resource.data.get('text', '').size() <= 500
                      && (
                        request.resource.data.get('text', '').size() > 0
                        || (request.resource.data.get('attachmentUrl', '') is string
                            && request.resource.data.get('attachmentUrl', '').size() > 0)
                        // (2026-05-22) multi-image: attachments[] (≤10) counts as content
                        || (request.resource.data.get('attachments', []) is list
                            && request.resource.data.get('attachments', []).size() > 0
                            && request.resource.data.get('attachments', []).size() <= 10)
                        // (2026-05-26) Feature 4 — sticker-only message (bundled/custom) counts as content
                        || (request.resource.data.get('sticker', {}) is map
                            && request.resource.data.sticker.get('kind', '') is string
                            && request.resource.data.sticker.get('kind', '').size() > 0)
                      )
                      // (AV198, 2026-06-21) "ระบบ" system notification cards are
                      // SERVER-ONLY (written by the sendPushOnSubmit Cloud Function via
                      // admin SDK, which bypasses rules). A client must not be able to
                      // FORGE one. Human messages carry no `system` field → unaffected.
                      // (2026-07-04 spec ③④ — NARROW exception) staff clients MAY create
                      // the two TFP kinds (tfp-vitals / tfp-doctor) written by
                      // TreatmentFormPage after a vitals/doctor save. intake/followup
                      // kinds stay server-only / unforgeable.
                      && (
                        !('system' in request.resource.data)
                        || (
                          request.resource.data.system is map
                          && request.resource.data.system.get('kind', '') in ['tfp-vitals', 'tfp-doctor']
                          && request.resource.data.system.get('treatmentId', '') is string
                          && request.resource.data.system.get('treatmentId', '').size() > 0
                          && request.resource.data.system.get('customerId', '') is string
                        )
                      );
        allow update: if false;             // still immutable-once-sent
        // (2026-05-26) Feature 3 Unsend — clinic-staff may delete (own-only
        // enforced UI-side via deviceId; the retention cron still uses admin SDK).
        // (AV198, 2026-06-21) but NOT "ระบบ" system cards — they are read-only at the
        // rule layer too (defense in depth); the retention cron (admin SDK) still reaps them.
        allow delete: if isClinicStaff() && !('system' in resource.data);
      }

      // ── Backend: Phase 29 Recall System (2026-05-14) ──
      // be_recalls is branch-scoped (branchId field) per BSA Rule L.
      // Customer-scoped queries are universal (sanctioned exception SG10:
      // recalls follow customer across branches).
      match /be_recalls/{recallId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 29.22 (2026-05-14) be_recall_cases ──
      // UNIVERSAL collection (no branchId) per BSA Rule L. Mirror
      // be_staff / be_doctors universal pattern. Soft-archive only
      // (allow delete: if false) — V41 soft-archive pattern. Probe-Deploy-
      // Probe (Rule B) endpoint #8 covers this rule.
      match /be_recall_cases/{caseId} {
        allow read: if isClinicStaff();
        allow create: if isClinicStaff();
        allow update: if isClinicStaff();
        // 2026-06-16 — hard-delete narrowed from `if false` to staff. SAFE:
        // recalls snapshot the case name as a STRING (no FK to caseId), so
        // deleting a master case never breaks historical recalls. Soft-archive
        // (isHidden) coexists. Probe-Deploy-Probe: staff delete → 200.
        allow delete: if isClinicStaff();
      }

      // ── Backend: Sales + Counter ──
      match /be_sales/{saleId} {
        allow read, write: if isClinicStaff();
      }
      match /be_sales_counter/{docId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 7 Finance (Deposits / Wallets / Memberships / Points) ──
      match /be_deposits/{depositId} {
        allow read, write: if isClinicStaff();
      }
      match /be_customer_wallets/{walletId} {
        allow read, write: if isClinicStaff();
      }
      // Phase 14.x: wallet + membership TYPES (master data) migrated from
      // master_data/wallet_types + master_data/membership_types. Reader
      // pattern flips via BE_BACKED_MASTER_TYPES so existing UIs pick up
      // transparently once migrated.
      match /be_wallet_types/{walletTypeId} {
        allow read, write: if isClinicStaff();
      }
      match /be_membership_types/{membershipTypeId} {
        allow read, write: if isClinicStaff();
      }
      // Phase 14.x gap audit: medicine label presets migrated from
      // master_data/medicine_labels. Consumed by Phase 16 print-label UI
      // (not shipped yet — collection exists to hold seeded ProClinic data).
      match /be_medicine_labels/{labelId} {
        allow read, write: if isClinicStaff();
      }
      match /be_wallet_transactions/{txId} {
        allow read, create: if isClinicStaff();
        // Wallet transactions are audit records — no update/delete from client.
        allow update, delete: if false;
      }
      match /be_memberships/{membershipId} {
        allow read, write: if isClinicStaff();
      }
      match /be_point_transactions/{txId} {
        allow read, create: if isClinicStaff();
        // Point transactions are audit records — no update/delete from client.
        allow update, delete: if false;
      }

      // ── Backend: Phase 9 Marketing (Promotions / Coupons / Vouchers) ──
      match /be_promotions/{promotionId} {
        allow read, write: if isClinicStaff();
      }
      match /be_coupons/{couponId} {
        allow read, write: if isClinicStaff();
      }
      match /be_vouchers/{voucherId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 11 Master Data Suite (our canonical master data) ──
      // Per Rule H: ALL master data in OUR Firestore. ProClinic sync remains
      // a seed-only path via MasterDataTab (writes master_data/*, read-only).
      // `be_*` below is the CRUD source of truth — one rule per Phase 11.X
      // task so Rule B probe-deploy-probe is only triggered once (when this
      // block ships in 11.2), not per-tab.
      match /be_product_groups/{groupId} {
        allow read, write: if isClinicStaff();
      }
      match /be_product_units/{unitId} {
        allow read, write: if isClinicStaff();
      }
      match /be_medical_instruments/{instrumentId} {
        allow read, write: if isClinicStaff();
      }
      match /be_holidays/{holidayId} {
        allow read, write: if isClinicStaff();
      }
      match /be_branches/{branchId} {
        allow read, write: if isClinicStaff();
      }
      // Phase 18.0 (2026-05-05) — branch-scoped exam-room master.
      // Standard be_* rule: any clinic staff can read/write. Branch isolation
      // is enforced at the application layer via _resolveBranchIdForWrite +
      // listExamRooms({branchId}) auto-inject.
      match /be_exam_rooms/{roomId} {
        allow read, write: if isClinicStaff();
      }
      // Tablet Chart Editor (2026-05-20) — pairing presence + session relay.
      // Both PC + tablet are clinic staff (Q2); branch-scoped at query time (BSA).
      match /be_chart_tablet_presence/{deviceId} {
        allow read, write: if isClinicStaff();
      }
      match /be_chart_edit_sessions/{sessionId} {
        allow read, write: if isClinicStaff();
      }
      match /be_permission_groups/{groupId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 12.1 People (staff + doctors / ผู้ช่วยแพทย์) ──
      // Firebase Auth account creation for these records goes through
      // /api/admin/users (Phase 12.0 endpoint) — Firestore side is just the
      // directory record; Admin SDK enforces its own admin gate.
      match /be_staff/{staffId} {
        allow read, write: if isClinicStaff();
      }
      match /be_doctors/{doctorId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 12.2 Catalog (products + courses with sub-items) ──
      match /be_products/{productId} {
        allow read, write: if isClinicStaff();
      }
      match /be_courses/{courseId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 12.5 Finance Master (bank accounts + expense cats + expenses) ──
      match /be_bank_accounts/{bankAccountId} {
        allow read, write: if isClinicStaff();
      }
      match /be_expense_categories/{categoryId} {
        allow read, write: if isClinicStaff();
      }
      match /be_expenses/{expenseId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 12.6 Online Sales (pre-sale status machine) ──
      match /be_online_sales/{onlineSaleId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 12.7 Sale Insurance Claims (multi-row per sale) ──
      match /be_sale_insurance_claims/{claimId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 14.1 Document Templates (13 ProClinic doc variants) ──
      // One collection, docType discriminator. Seeded on first load; staff
      // can edit all, delete only non-system (isSystemDefault guard enforced
      // at CRUD layer — rules just gate staff-auth).
      match /be_document_templates/{templateId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 14.9 Document Print Audit Log (append-only) ──
      // V19/V31 lesson — append-only contracts MUST be enforced at rule
      // layer, not just code. Update + delete forbidden so a compromised
      // client can't tamper print history. Read allowed for clinic staff
      // (admin needs to inspect "who printed what for whom" for compliance).
      match /be_document_prints/{printId} {
        allow read:   if isClinicStaff();
        allow create: if isClinicStaff();
        allow update, delete: if false;
      }

      // ── Backend: Phase 14.10 Document Print Drafts (resumable form fill) ──
      // Drafts are mutable — admin can save partial fill, resume later,
      // or delete when no longer needed. Read+write open to clinic staff.
      // Caller's staffUid is recorded so admin can scope drafts to "my
      // drafts" in the future.
      match /be_document_drafts/{draftId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: T4 / Phase 14.4 G5 Course Exchange + Refund Audit Log ──
      // V32-tris-bis (2026-04-26) — course exchanges + refunds are written
      // here as immutable audit entries via runTransaction. Same append-
      // only contract as be_document_prints / be_stock_movements so a
      // compromised client can't tamper exchange history.
      match /be_course_changes/{changeId} {
        allow read:   if isClinicStaff();
        allow create: if isClinicStaff();
        allow update, delete: if false;
      }

      // ── Backend: ED Score follow-up assessment rounds (2026-06-15) ──
      // UNIVERSAL collection (customer-scoped via customerId field, no branchId).
      // Unlike be_course_changes (append-only), rounds ARE deletable by staff
      // (Q4 mis-fill recovery; round# is derived not stored → delete renumbers).
      // update allowed: the onPatientSubmit Cloud Function (admin SDK, bypasses
      // rules) patches pending→completed; staff client may also edit. Anon write
      // → 403 (Probe-Deploy-Probe Rule B endpoint #17).
      match /be_assessments/{assessmentId} {
        allow read:   if isClinicStaff();
        allow create: if isClinicStaff();
        allow update: if isClinicStaff();
        allow delete: if isClinicStaff();
      }

      // ── Backend: AP1 (2026-05-04) Appointment slot reservation ──
      // Atomic collision guard for createBackendAppointment. Each slot doc
      // ID encodes `${date}_${doctorId}_${startTime}_${endTime}` so the
      // createBackendAppointment runTransaction can `tx.get(slotDocRef)` →
      // throw on existence → otherwise `tx.set` BOTH the slot AND the
      // appointment atomically. Eliminates the ~1s read-then-write race.
      // Slot docs are deleted when the appointment is deleted/cancelled.
      // No append-only constraint needed (slots are short-lived guards).
      match /be_appointment_slots/{slotId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 16.1 (2026-04-30) Smart Audience saved segments ──
      // Marketing query rules persisted as serialized rule trees:
      //   { rule: { kind: 'group', op: 'AND'|'OR', children: [...] }, name, ... }
      // Read+write open to clinic staff. Hard-delete in v1 (soft-delete +
      // audit ledger reserved for v2 if marketing-team usage warrants it).
      // Per Rule E + H + H-quater: feature reads only be_* (be_customers +
      // be_sales + be_audiences); zero master_data reads in feature code.
      match /be_audiences/{audienceId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: V32-tris-ter (2026-04-26) LINE Customer Link Tokens ──
      // V33.9 — be_customer_link_tokens rule REMOVED. Pre-V33.4 QR-token
      // flow stripped (admin-mint endpoint + webhook consumer + client
      // helper deleted). Default-deny applies to any residual ghost docs;
      // they're inert. Admin-mediated id-link-request via be_link_requests
      // below is the sole linking mechanism.

      // ── Backend: V32-tris-quater (2026-04-26) LINE Link Requests Queue ──
      // Customer DM'd "ผูก <ID>" → webhook validated ID via admin SDK +
      // created pending request here. Admin reviews + approves/rejects via
      // /api/admin/link-requests (firebase-admin SDK). Client SDK reads
      // blocked — request docs include lineDisplayName/picture which is
      // PII. LinkRequestsTab fetches via the admin endpoint.
      match /be_link_requests/{requestId} {
        allow read, write: if false;
      }

      // ── Backend: V32-tris-quater (2026-04-26) Rate-limit attempts ──
      // Tracks lineUserId → [timestamps[]] for the 5-per-24h cap on
      // id-link-request submissions. Admin SDK only.
      match /be_link_attempts/{lineUserId} {
        allow read, write: if false;
      }

      // ── Backend: Phase BS V3 (2026-05-04) Per-branch LINE OA configs ──
      // Each branch has its own LINE Official Account channel. Webhook
      // routes incoming events by event.destination → resolves branchId.
      // Read open to clinic staff so LineSettingsTab can render. Write
      // gated to admin OR system_config_management permission (mirror of
      // clinic_settings/system_config gate).
      match /be_line_configs/{branchId} {
        allow read: if isClinicStaff();
        allow create, update: if isSignedIn() && (
          request.auth.token.admin == true ||
          request.auth.token['perm_system_config_management'] == true
        );
        allow delete: if isSignedIn() && request.auth.token.admin == true;
      }

      // ── Backend: V75 Item 3 (2026-05-16) Per-branch FB Page configs ──
      // Mirror of be_line_configs. Each branch has its own FB Page +
      // Messenger webhook config. Webhook routes incoming events by
      // entry[].id (Page ID) → resolves branchId via be_fb_configs.
      // Read open to clinic staff so FbSettingsTab can render. Write
      // gated to admin OR system_config_management permission.
      match /be_fb_configs/{branchId} {
        allow read: if isClinicStaff();
        allow create, update: if isSignedIn() && (
          request.auth.token.admin == true ||
          request.auth.token['perm_system_config_management'] == true
        );
        allow delete: if isSignedIn() && request.auth.token.admin == true;
      }

      // ── Backend: Phase 15.6 (2026-04-28) Admin cleanup audit log ──
      // Written ONLY by /api/admin/cleanup-* endpoints (firebase-admin SDK
      // bypasses rules). Lists deleted batch / product / sale IDs + caller
      // email + timestamp for forensic review. Client SDK locked EXCEPT
      // for Phase 16.3 system-config-* docs (admin/perm-gated CREATE so
      // saveSystemConfig writes audit + system_config atomically in one
      // batch from the client).
      match /be_admin_audit/{auditId} {
        allow read: if isClinicStaff();
        // Phase 16.3 (2026-04-29) — narrow exception for system-config-*
        // audit docs. Same gate as the system_config doc itself (Q2-C).
        // Phase 24.0 (2026-05-06) — narrow exception for customer-delete-*
        // audit docs. Server endpoint /api/admin/delete-customer-cascade
        // uses firebase-admin SDK (bypasses rules) but we narrow-allow the
        // client-side prefix anyway so emergency manual writes from a
        // perm-gated admin remain possible. Same dual gate as system-config.
        allow create: if isSignedIn() && (
                         (
                           auditId.matches('^system-config-.*') && (
                             request.auth.token.admin == true ||
                             request.auth.token['perm_system_config_management'] == true
                           )
                         ) ||
                         (
                           auditId.matches('^customer-delete-.*') && (
                             request.auth.token.admin == true ||
                             request.auth.token['perm_customer_delete'] == true
                           )
                         )
                       );
        allow update, delete: if false;  // immutable
      }

      // ── Backend: LINE OA Appointment Reminder (2026-05-15) ──
      // be_line_reminder_log — fire/retry/expire/postback audit ledger.
      // Written by /api/cron/line-reminder-fire + retry + /api/webhook/line
      // postback handler via firebase-admin SDK (bypasses rules). Read by
      // admin LineRemindersTab via /api/admin/line-reminder-logs endpoint
      // AND by LineReminderHistoryPanel via client-SDK onSnapshot.
      // Append-only; WRITE locked at rules layer. Rule B probe #8 verifies
      // anon → 403 (anon clients are not clinic staff → no read either).
      //
      // 2026-05-15 (Wave 2 deferred fix): READ opened to clinic staff for
      // LineReminderHistoryPanel (§5 C.3). WRITE still locked — admin-SDK +
      // cron only. Pre-Wave-2: both read+write were `if false`; that prevented
      // the history panel from rendering any logs in production.
      match /be_line_reminder_log/{logId} {
        allow read: if isClinicStaff();
        allow write: if false;  // admin-SDK + cron only (LINE OA reminder pipeline)
      }
      // be_line_reminder_postback_log — atomic guard against duplicate
      // postback action handling (LINE may redeliver). Doc id = postbackToken.
      // Written by /api/webhook/line postback handler via firebase-admin SDK.
      // WRITE locked at rules layer. Rule B probe #8 verifies anon → 403.
      //
      // 2026-05-15 (Wave 2 deferred fix): READ opened to clinic staff for
      // LineReminderHistoryPanel (§5 C.3). WRITE still locked — admin-SDK +
      // webhook only. Pre-Wave-2: both read+write were `if false`; that prevented
      // the history panel from rendering any logs in production.
      match /be_line_reminder_postback_log/{id} {
        allow read: if isClinicStaff();
        allow write: if false;  // admin-SDK + webhook only (LINE OA postback log)
      }

      // ── Backend: Phase 14.3 (G6) Vendors + Vendor Sales (B2B sale variant) ──
      match /be_vendors/{vendorId} {
        allow read, write: if isClinicStaff();
      }
      match /be_vendor_sales/{saleId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 13.1 Quotations (OUR data; no ProClinic mirror) ──
      match /be_quotations/{quotationId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 13.2 Staff Schedules (work/holiday/leave per staff per date) ──
      match /be_staff_schedules/{scheduleId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 13.3 DF (Doctor Fee) Groups + Staff-rate overrides ──
      match /be_df_groups/{groupId} {
        allow read, write: if isClinicStaff();
      }
      match /be_df_staff_rates/{staffId} {
        allow read, write: if isClinicStaff();
      }

      // ── Backend: Phase 8 Stock (Orders / Batches / Movements / Adjustments / Transfers / Withdrawals) ──
      match /be_stock_orders/{orderId} {
        allow read: if isClinicStaff();
        allow create, update: if isClinicStaff();
        // Orders are cancelled (status='cancelled'), never deleted — preserve history.
        allow delete: if false;
      }
      match /be_stock_batches/{batchId} {
        allow read: if isClinicStaff();
        allow create, update: if isClinicStaff();
        // V144 (2026-06-02) — a 0-remaining lot holds no stock; its history lives
        // in the immutable be_stock_movements (Rule O / never deleted). The 03:45
        // cron already hard-deletes redundant 0-lots (admin SDK); this opens the
        // SAME delete to the client SDK for real-time redundant-0-lot auto-clear
        // (AV172) — but ONLY when remaining == 0. Live (>0) + negative-debt (<0)
        // lots stay UNDELETABLE (FIFO audit preserved; defense-in-depth — even a
        // buggy caller can't delete a lot that holds stock or debt).
        allow delete: if isClinicStaff() && resource.data.qty.remaining == 0;
      }
      match /be_stock_movements/{movementId} {
        allow read, create: if isClinicStaff();
        // MOVEMENTS ARE IMMUTABLE EXCEPT for the reversal-link field.
        // _reverseOneMovement creates a new compensating movement and then
        // sets `reversedByMovementId` on the original to point to it. That
        // single-field update is the only legitimate write; everything else
        // stays locked for MOPH audit integrity.
        // Phase 14.7.F (2026-04-26) — narrowed from `allow update: if false`
        // after bug "คืนสต็อกการรักษาเดิมไม่สำเร็จ: Missing or insufficient
        // permissions" surfaced when an edit-treatment legitimately reversed
        // its prior stock movements.
        allow update: if isClinicStaff() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reversedByMovementId']);
        allow delete: if false;
      }
      match /be_stock_adjustments/{adjustId} {
        allow read, create: if isClinicStaff();
        // Adjustments are audit records paired with a movement — no update/delete.
        allow update, delete: if false;
      }
      match /be_stock_transfers/{transferId} {
        allow read: if isClinicStaff();
        // Transfers mutate via status transitions (0→1→2→3/4); updates allowed, deletes blocked.
        allow create, update: if isClinicStaff();
        allow delete: if false;
      }
      match /be_stock_withdrawals/{withdrawalId} {
        allow read: if isClinicStaff();
        allow create, update: if isClinicStaff();
        allow delete: if false;
      }
      match /be_central_stock_warehouses/{stockId} {
        allow read: if isClinicStaff();
        allow create, update: if isClinicStaff();
        // Soft-delete only (isActive=false) — audit trail preserved.
        allow delete: if false;
      }

      // Phase 15.2 (2026-04-27) — Central PO (vendor → central warehouse).
      // Status flips: pending → partial → received | cancelled |
      // cancelled_post_receive. Never deleted (audit trail).
      match /be_central_stock_orders/{orderId} {
        allow read: if isClinicStaff();
        allow create, update: if isClinicStaff();
        allow delete: if false;
      }
      // Atomic counter for PO-CST-YYYYMM-NNNN sequence.
      match /be_central_stock_orders_counter/{counterId} {
        allow read, write: if isClinicStaff();
      }

      // V50 (2026-05-08) — `master_data/*` block REMOVED. ProClinic dev-only
      // sync infrastructure deleted in V50 Phase 2.2 + 2,599 docs cleaned in
      // Phase 6. Default-deny applies to any residual ghost docs; they're
      // inert. AV28 audit invariant locks no runtime reads/writes of these
      // collections from src/.

      // ── Treatment chart/image backups ──
      match /treatments/{treatmentId} {
        allow read, write: if isClinicStaff();
      }

      // ── Chart templates ──
      match /chart_templates/{docId} {
        allow read: if isSignedIn();
        allow write: if isClinicStaff();
      }

      // ── Chart templates (canonical Rule H — per-doc, universal,
      //    used by ChartTemplateSelector). 2026-05-22 EOD+1 rewrite —
      //    previous code wrote to `pc_chart_templates` which had no
      //    matching rule → default-deny → silent upload-not-persisted bug.
      //    Each template = one doc {id, name, category, imageUrl,
      //    storagePath, builtIn, locked, _seedOrder, createdAt, updatedAt}.
      //    Image bytes live in Storage at chart-templates/{id}.{ext}. ──
      match /be_chart_templates/{templateId} {
        // WS1 M2 (2026-06-10) — KEPT signed-in read (NOT split to staff-list).
        // ChartTemplateSelector subscribes via onSnapshot(query(be_chart_templates))
        // = a LIST, and anon patients reach it through TFP, so a list→staff split
        // would break the patient chart-template picker. These are low-PII medical
        // diagram templates (name/category/imageUrl) — accepted residual.
        allow read: if isSignedIn();   // patients reach via TFP (list needed by ChartTemplateSelector)
        allow write: if isClinicStaff();
      }

      // ── Clinic Schedules (booking) ──
      match /clinic_schedules/{scheduleId} {
        // WS1 H2 (2026-06-10) — split read + tighten write. The patient booking
        // page (ClinicSchedule.jsx:90) only getDoc(clinic_schedules, token) — a
        // GET by crypto token; it never lists and never writes. So: GET stays
        // public, LIST is staff-only (kills anon enumeration), WRITE is staff-only
        // (all schedule authors are AdminDashboard staff — anon could previously
        // overwrite/vandalize public booking docs via signInAnonymously).
        allow get:   if true;            // Public: patient booking page reads by token
        allow list:  if isClinicStaff();
        allow write: if isClinicStaff();
      }

      // ── Chat conversations ──
      // Webhook (api/webhook/facebook.js + line.js) writes new messages from
      // FB Messenger / LINE without Firebase auth — Vercel serverless has no
      // firebase-admin SDK on this path. Reads are staff-only; create/update
      // is open so the unauthenticated webhook can land messages.
      // Delete stays staff-only so internet randos can't wipe history.
      match /chat_conversations/{convId} {
        allow read: if isClinicStaff();
        // WS1 H1 (2026-06-10) — tightened create/update from `if true`. Every
        // webhook writer (api/webhook/line.js + facebook.js + send.js) now writes
        // via the firebase-admin SDK (getAdminFirestore/adminChatSet) which BYPASSES
        // rules — so dropping the anon `if true` does NOT break inbound/outbound
        // messages. Staff client-SDK writes pass isClinicStaff(). Closes the open-
        // internet write/spam/forge surface. Rule B probe: anon create → DENIED.
        allow create, update: if isClinicStaff();
        allow delete: if isClinicStaff();

        match /messages/{messageId} {
          allow read: if isClinicStaff();
          // WS1 H1 — webhook message writes use admin SDK (bypass rules); staff
          // client-SDK writes pass isClinicStaff(). Anon REST create now DENIED.
          allow create: if isClinicStaff();
          allow update, delete: if isClinicStaff();
        }
      }

      // ── Chat history (archived) ──
      match /chat_history/{histId} {
        allow read, write: if isClinicStaff();
      }

      // V50 (2026-05-08) — `pc_*` mirror blocks REMOVED. ProClinic dev-only
      // sync infrastructure deleted in V50 Phase 2.2; 2,097 mirror docs
      // cleaned in Phase 6 (pc_treatments=1132 + pc_customers=450 +
      // pc_courses=244 + pc_treatment_history=247 + pc_appointments=14 +
      // pc_chart_templates=3 + pc_form_options=2 + pc_inventory=2 +
      // pc_doctors=1 + pc_customer_appointments=2). Default-deny applies
      // to any residual ghost docs; inert. AV28 audit invariant locks no
      // runtime reads/writes from src/.

      // ── Chat config ──
      match /chat_config/{docId} {
        allow read: if isClinicStaff();
        allow write: if isClinicStaff();
      }

      // ── Presence (online status) ──
      // Anti-vibe-code AV2: tightened to clinic staff only — admin_presence was
      // previously readable/writable by any signed-in Firebase user, which is
      // too permissive (a stray web app signed into our Firebase project could
      // read the admin tab list). AdminDashboard is the only writer.
      match /admin_presence/{tabId} {
        allow read: if isClinicStaff();
        allow write: if isClinicStaff();
      }

      // ── FCM tokens (legacy — no code path writes to this collection anymore;
      //    the real push-subscriber list lives at push_config/tokens — see the
      //    push_config rule below).
      //    Left intentionally locked so the dead collection stays dead. ──
      match /fcm_tokens/{tokenId} {
        allow read, write: if isClinicStaff();
      }

      // ── Push notification config (2026-05-26 — AV138 fix) ──
      //    push_config/tokens   = live web-push FCM subscriber list. The browser
      //      (clinic-staff) registers its device token here on "เปิดการแจ้งเตือน
      //      มือถือ"; the Cloud Function sendPushOnSubmit reads it via admin SDK
      //      (bypasses rules). The app-load self-heal re-registers the current
      //      token. push_config/settings = globalPushMuted test-mode toggle.
      //    CLIENT reads + writes BOTH docs → REQUIRES this rule. It was MISSING
      //    (the older broad public/data allow was dropped in the per-collection
      //    rules refactor ~c0d0ffc and push_config was forgotten — never had a
      //    match block), so client read/write fell through to the default-deny
      //    catch-all → "Missing or insufficient permissions" on enable-push for
      //    ~2 months (the 7 stored tokens predate the regression). Added to the
      //    Rule B probe list so it can't silently regress again.
      match /push_config/{docId} {
        allow read, write: if isClinicStaff();
      }

      // V50 (2026-05-08) — `proclinic_session/*` + `broker_jobs/*` blocks
      // REMOVED. Cookie-relay extension (Chrome MV3) + broker-job orchestrator
      // deleted in V50 Phase 2.2 (-10,318 LOC infrastructure strip). Default-
      // deny applies to any residual ghost docs. AV28 audit invariant locks
      // no runtime references from src/ or api/.
    }
  }
}
