    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.10.3",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.577.0",
