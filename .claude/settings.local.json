{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(cat firestore.indexes.json)",
      "Bash(ls firestore.*)",
      "Bash(npx vitest *)",
      "Bash(npm run *)",
      "Bash(grep -E \"^\\(audit-rules|audit-health|skill-relevant|research-gap|skill-autoinstall\\)$\")",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Skill(using-superpowers)",
      "Skill(using-superpowers:*)",
      "Bash(rtk grep *)",
      "Bash(bash scripts/deploy-office-to-pdf-cloud-run.sh)",
	  "Bash(node scripts/_extract-sa-key.mjs:*)",
      "Bash(gcloud auth activate-service-account:*)",
      "Bash(grep \"ADMIN\" .env.local.prod:*)",
      "Bash(head .env.local.prod:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "outputStyle": "concise",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "autoCompactThreshold": 80
}
