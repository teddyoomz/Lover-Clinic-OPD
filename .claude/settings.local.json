{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(cat firestore.indexes.json)",
      "Bash(ls firestore.*)",
      "Bash(npx vitest *)",
      "Bash(npm run *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "outputStyle": "concise",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "autoCompactThreshold": 80
}
